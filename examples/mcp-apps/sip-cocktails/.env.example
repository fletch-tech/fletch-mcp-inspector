# Required: main app URL; users are redirected here when token is missing or invalid
MAIN_URL=https://your-main-app.com

# Convex (required for Convex backend)
CONVEX_URL=
# or VITE_CONVEX_URL=

# JWT validation (external issuer)
# Issuer of the JWT (must match JWT iss claim). Required for Convex and server.
JWT_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxx

# JWKS URL for RS256 verification. Optional if using Cognito env vars below.
JWT_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxx/.well-known/jwks.json

# Cognito: alternative to JWT_JWKS_URL (server and Convex build JWKS URL from these)
# AWS_REGION=us-east-1
# USER_POOL_ID=us-east-1_xxxxx

# Optional: verify JWT aud claim (e.g. Cognito App Client ID)
JWT_AUDIENCE=your-app-client-id

# Optional: fallback for HS256 verification if no JWKS / no matching key
# JWT_SECRET=

# Optional: public URL of this server (for redirects and cookies)
# PUBLIC_URL=http://localhost:3001
