# Copy to .env and set values. Must match the app that connects to this Convex (e.g. mcpjam-inspector .env.production).

# CRITICAL for production: must be the PUBLIC URL the client uses (VITE_CONVEX_URL).
# If clients connect to https://sb-convex-cloud.fletch.co but this is unset or http://127.0.0.1:3210, WebSocket can close with 1011.
CONVEX_CLOUD_ORIGIN=https://sb-convex-cloud.fletch.co
CONVEX_SITE_ORIGIN=https://sb-convex-cloud.fletch.co/http

# If the Convex dashboard is on a different domain (e.g. https://sb-convex.fletch.co) and you see CORS errors
# for /api/app_metrics/stream_function_logs, the backend may need to allow that origin. If convex-backend
# supports an env var like ADDITIONAL_ALLOWED_ORIGINS or CONVEX_DASHBOARD_ORIGIN, set it here. See README.
# CONVEX_DASHBOARD_ORIGIN=https://sb-convex.fletch.co

# JWT (Cognito or custom) – required for auth; missing/wrong values can cause 1011
JWT_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxxxx
JWT_JWKS_URL=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxxxx/.well-known/jwks.json
# Or instead of JWT_JWKS_URL: AWS_REGION=us-east-2 and USER_POOL_ID=us-east-2_xxxxx
JWT_AUDIENCE=

# Backend ports (optional)
# PORT=3210
# SITE_PROXY_PORT=3211

# ── S3 storage (optional; for shared modules across cloud + site backends) ─────
# Bucket names are required when using S3. Set the same bucket + credentials on BOTH cloud and site backends so they share deployed code.
# Minimum for shared modules only: AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, S3_STORAGE_MODULES_BUCKET.
# S3_STORAGE_MODULES_BUCKET=convex-modules
# AWS_REGION=us-east-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional (other storage): S3_STORAGE_EXPORTS_BUCKET, S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET, S3_STORAGE_FILES_BUCKET, S3_STORAGE_SEARCH_BUCKET
# For R2 or non-AWS S3: S3_ENDPOINT_URL=https://...
# INSTANCE_SECRET: for ECS, set a fixed value (e.g. from Secrets Manager) so all tasks accept the same admin key (see README).
# Add any other Convex backend env your deployment needs (e.g. DATABASE_URL, INSTANCE_SECRET).
# If you see "Src Pkg storage key not found" in backend logs, redeploy the app to this backend (see README).
