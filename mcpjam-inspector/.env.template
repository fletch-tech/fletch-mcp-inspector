ENVIRONMENT=production

# ── Self-hosted Convex: set these so the app and backend match ─────────────────
# Client (browser) connects here for WebSocket. Set at build time for production (e.g. docker:build).
VITE_CONVEX_URL=http://127.0.0.1:3210
# Server-side: Convex backend URL. Must be the HTTP-actions endpoint (see CONVEX_HTTP_URL), or leave unset.
# If you set this to the sync port (3210) only, you'll see "This Convex deployment does not have HTTP actions enabled".
CONVEX_SELF_HOSTED_URL=
# Server-side: HTTP-actions base for tunnels, stream, auth (e.g. port 3211 or site host). Required for chat/stream and web auth.
CONVEX_HTTP_URL=http://127.0.0.1:3211
# Required for deploy and dashboard; generate via backend: ./generate_admin_key.sh
CONVEX_SELF_HOSTED_ADMIN_KEY=

# For production (e.g. sandbox): use your public Convex URLs and rebuild the app image.
#   VITE_CONVEX_URL=https://sb-convex-cloud.fletch.co   (sync; client WebSocket)
#   If HTTP actions use a path prefix (matches Convex CONVEX_SITE_ORIGIN, e.g. .../http):
#   CONVEX_HTTP_URL=https://sb-convex-cloud.fletch.co/http
#   Or a dedicated site host with no prefix:
#   CONVEX_HTTP_URL=https://sb-convex-site.fletch.co
#   (Leave CONVEX_SELF_HOSTED_URL unset, or set to same as CONVEX_HTTP_URL.)

# ── JWT (Cognito or custom): same as Convex backend env ────────────────────────
USER_POOL_ID=
JWT_ISSUER=
JWT_JWKS_URL=
JWT_AUDIENCE=

MAIN_URL='http://localhost:3001'

# *.fletch.co production domain support
CORS_WILDCARD_DOMAINS='*.fletch.co'
MCPJAM_ALLOWED_HOSTS='*.fletch.co'
